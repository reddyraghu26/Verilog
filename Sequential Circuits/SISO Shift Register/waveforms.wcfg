<?xml version="1.0" encoding="UTF-8"?>
<wave_config>
   <wave_state>
   </wave_state>
   <db_ref_list>
      <db_ref path="tb_behav.wdb" id="1">
         <top_modules>
            <top_module name="glbl" />
            <top_module name="tb" />
         </top_modules>
      </db_ref>
   </db_ref_list>
   <zoom_setting>
      <ZoomStartTime time="0.000 ns"></ZoomStartTime>
      <ZoomEndTime time="127.201 ns"></ZoomEndTime>
      <Cursor1Time time="28.100 ns"></Cursor1Time>
   </zoom_setting>
   <column_width_setting>
      <NameColumnWidth column_width="147"></NameColumnWidth>
      <ValueColumnWidth column_width="78"></ValueColumnWidth>
   </column_width_setting>
   <WVObjectSize size="5" />
   <wvobject fp_name="/tb/data" type="logic">
      <obj_property name="ElementShortName">data</obj_property>
      <obj_property name="ObjectShortName">data</obj_property>
   </wvobject>
   <wvobject fp_name="/tb/clk" type="logic">
      <obj_property name="ElementShortName">clk</obj_property>
      <obj_property name="ObjectShortName">clk</obj_property>
   </wvobject>
   <wvobject fp_name="/tb/clr" type="logic">
      <obj_property name="ElementShortName">clr</obj_property>
      <obj_property name="ObjectShortName">clr</obj_property>
   </wvobject>
   <wvobject fp_name="/tb/out" type="logic">
      <obj_property name="ElementShortName">out</obj_property>
      <obj_property name="ObjectShortName">out</obj_property>
   </wvobject>
   <wvobject fp_name="/tb/in" type="array">
      <obj_property name="ElementShortName">in[3:0]</obj_property>
      <obj_property name="ObjectShortName">in[3:0]</obj_property>
   </wvobject>
</wave_config>
